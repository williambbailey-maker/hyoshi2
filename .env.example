# Copy this file to ".env" and fill in your Supabase project values.
# Find these in Supabase: Project Settings -> API.
# Note: VITE_ vars are bundled into the browser app (publishable values only).
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-anon-key

# SERVER-SIDE ONLY — do NOT add a VITE_ prefix (that would expose it in the browser).
# Your Google Calendar "Secret address in iCal format" (ends in /basic.ics).
# This is read only by the serverless function in /api/calendar.js.
# In production, set this in Vercel -> Project -> Settings -> Environment Variables.
# Locally it is only used when running `vercel dev` (plain `npm run dev` skips /api).
CALENDAR_ICAL_URL=https://calendar.google.com/calendar/ical/.../basic.ics
